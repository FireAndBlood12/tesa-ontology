<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:cf="http://example.org/tesa/carfactory#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:time="http://www.w3.org/2006/time#"
  xmlns:tesa="http://example.org/tesa#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <owl:Ontology rdf:about="http://example.org/tesa/carfactory">
    <owl:imports rdf:resource="http://example.org/tesa"/>
    <rdfs:comment xml:lang="en">Car factory test system for the TESA ontology: entity hierarchy, time triggers, actions, priorities and conflict groups.</rdfs:comment>
  </owl:Ontology>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_DailyShiftStart_East">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Daily day-shift start at Plant East</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/carfactory#TT_DailyShiftStart_East_time">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">6</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval>
      <time:Interval rdf:about="http://example.org/tesa/carfactory#IV_Shift1_2026">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Day shift window, production year 2026</rdfs:label>
        <time:hasBeginning rdf:resource="http://example.org/tesa/carfactory#IV_Shift1_2026_beg"/>
        <time:hasEnd rdf:resource="http://example.org/tesa/carfactory#IV_Shift1_2026_end"/>
      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_StartConveyor_East">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Start main conveyor, Plant East</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Plant_East"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_07"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Shift1_2026"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_WeeklyMaintenance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Weekly maintenance, Friday 22:00</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/carfactory#TT_WeeklyMaintenance_time">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <time:dayOfWeek rdf:resource="http://www.w3.org/2006/time#Friday"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">22</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval>
      <time:Interval rdf:about="http://example.org/tesa/carfactory#IV_MaintenanceWeekend">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>July maintenance weekend</rdfs:label>
        <time:hasBeginning rdf:resource="http://example.org/tesa/carfactory#IV_MaintenanceWeekend_beg"/>
        <time:hasEnd rdf:resource="http://example.org/tesa/carfactory#IV_MaintenanceWeekend_end"/>
      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_LockdownStations">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Lock down stations for maintenance</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Plant_North"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_09"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_MaintenanceWeekend"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_ResumeProduction"/>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_LubricateConveyor">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Lubricate conveyor system</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Plant_North"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_05"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_MaintenanceWeekend"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <tesa:ConflictedActions rdf:about="http://example.org/tesa/carfactory#CA_Changeover">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Line changeover vs keeping sedan output</rdfs:label>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_ChangeoverSedanToEV">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Change over Sedan line to EV</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#PL_East_Sedan"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_06"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Changeover_Aug"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_KeepSedanOutput"/>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_HaltForChangeover"/>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_KeepSedanOutput">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Keep East Sedan output for backlog</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#PL_East_Sedan"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_02"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Changeover_Aug"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_HaltForChangeover"/>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_HaltForChangeover">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Halt East Sedan output for changeover</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#PL_East_Sedan"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_06"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Changeover_Aug"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:ConflictedActions>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_NightWindowStart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Night window start</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/carfactory#TT_NightWindowStart_time">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">22</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval>
      <time:Interval rdf:about="http://example.org/tesa/carfactory#IV_NightWindow_2026">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Night window: charging and maintenance</rdfs:label>
        <time:hasBeginning rdf:resource="http://example.org/tesa/carfactory#IV_NightWindow_2026_beg"/>
        <time:hasEnd rdf:resource="http://example.org/tesa/carfactory#IV_NightWindow_2026_end"/>
      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_ChargeEVBatteries">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Charge EV battery packs</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#PL_North_EV"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_06"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_NightWindow_2026"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_StopConveyor_North">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Stop main conveyor, Plant North</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Plant_North"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_08"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_NightWindow_2026"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_StopConveyor_East">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Stop main conveyor, Plant East</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Plant_East"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_08"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_NightWindow_2026"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_QualitySampling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Per-shift quality sampling</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/carfactory#TT_QualitySampling_time">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">12</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Shift1_2026"/>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_SampleQuality">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Sample per-shift product quality</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Div_Quality"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_05"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Shift1_2026"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_MonthlyAudit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Monthly audit, first Monday 08:00</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/carfactory#TT_MonthlyAudit_time">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <time:dayOfWeek rdf:resource="http://www.w3.org/2006/time#Monday"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">8</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval>
      <time:Interval rdf:about="http://example.org/tesa/carfactory#IV_AuditWindow_Jul">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Monthly audit window, July</rdfs:label>
        <time:hasBeginning rdf:resource="http://example.org/tesa/carfactory#IV_AuditWindow_Jul_beg"/>
        <time:hasEnd rdf:resource="http://example.org/tesa/carfactory#IV_AuditWindow_Jul_end"/>
      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_AuditLine_NorthSedan">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Audit North Sedan line</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#PL_North_Sedan"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_05"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_AuditWindow_Jul"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_HolidayShutdown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Holiday shutdown start (December)</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/carfactory#TT_HolidayShutdown_time">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <time:monthOfYear rdf:resource="http://www.w3.org/ns/time/gregorian#December"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval>
      <time:Interval rdf:about="http://example.org/tesa/carfactory#IV_HolidayShutdown">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Holiday shutdown</rdfs:label>
        <time:hasBeginning rdf:resource="http://example.org/tesa/carfactory#IV_HolidayShutdown_beg"/>
        <time:hasEnd rdf:resource="http://example.org/tesa/carfactory#IV_HolidayShutdown_end"/>
      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_ShutdownAllLines">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Shut down all lines for holidays</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#CC_Global"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_10"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_HolidayShutdown"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <tesa:ConflictedActions rdf:about="http://example.org/tesa/carfactory#CA_EnergyPeak">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Energy-peak reduction vs Q3 production boost vs overtime</rdfs:label>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_ReduceEnergyLoad">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Reduce energy load during grid peak</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#CC_Global"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_10"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_EnergyPeak"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_BoostProduction"/>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_OvertimeWindow"/>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_BoostProduction">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Boost production for Q3 targets</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#CC_Global"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_03"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Q3_2026"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_OvertimeWindow"/>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_OvertimeWindow">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Open overtime window</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Plant_East"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_02"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Q3_2026"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:ConflictedActions>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_PaintSlotMorning">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Morning paint slot allocation</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/carfactory#TT_PaintSlotMorning_time">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">8</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval>
      <time:Interval rdf:about="http://example.org/tesa/carfactory#IV_PaintSlot_A">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Paint booth slot A</rdfs:label>
        <time:hasBeginning rdf:resource="http://example.org/tesa/carfactory#IV_PaintSlot_A_beg"/>
        <time:hasEnd rdf:resource="http://example.org/tesa/carfactory#IV_PaintSlot_A_end"/>
      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_PaintSedanBatch">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Paint sedan batch in shared booth</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#ST_North_Sedan_PNT"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_06"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_PaintSlot_A"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_PaintSUVBatch"/>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_PreheatPaintBooth"/>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_PaintSUVBatch">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Paint SUV batch in shared booth</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#ST_North_Sedan_PNT"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_04"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_PaintSlot_B"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_PreheatPaintBooth"/>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <tesa:ConflictedActions rdf:about="http://example.org/tesa/carfactory#CA_MaintenanceVsProduction">
