      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_RotateInspectors">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
