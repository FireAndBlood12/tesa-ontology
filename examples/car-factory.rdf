      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Shift1_2026"/>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_StartConveyor_North">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Start main conveyor, Plant North</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Plant_North"/>
