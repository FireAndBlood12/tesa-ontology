  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_SoftwareUpdate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Firmware update, Saturday 02:00</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/carfactory#TT_SoftwareUpdate_time">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <time:dayOfWeek rdf:resource="http://www.w3.org/2006/time#Saturday"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval>
      <time:Interval rdf:about="http://example.org/tesa/carfactory#IV_FirmwareWindow">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Firmware update window</rdfs:label>
        <time:hasBeginning rdf:resource="http://example.org/tesa/carfactory#IV_FirmwareWindow_beg"/>
        <time:hasEnd rdf:resource="http://example.org/tesa/carfactory#IV_FirmwareWindow_end"/>
      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_UpdateRobotFirmware">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Update robot firmware</rdfs:label>
        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Plant_North"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_07"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_FirmwareWindow"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
        <tesa:conflictsWith rdf:resource="http://example.org/tesa/carfactory#A_RunDiagnostics"/>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/carfactory#TT_QuarterlyInventory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Quarterly inventory, July 1st pattern</rdfs:label>
