      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:validDuringInterval>
      <time:Interval rdf:about="http://example.org/tesa/carfactory#IV_Q3_2026">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>Third quarter 2026</rdfs:label>
        <time:hasBeginning rdf:resource="http://example.org/tesa/carfactory#IV_Q3_2026_beg"/>
        <time:hasEnd rdf:resource="http://example.org/tesa/carfactory#IV_Q3_2026_end"/>
      </time:Interval>
    </tesa:validDuringInterval>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/carfactory#A_RunInventory">
