        <cf:appliesTo rdf:resource="http://example.org/tesa/carfactory#Div_Quality"/>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/carfactory#PR_03"/>
        <tesa:validDuringInterval rdf:resource="http://example.org/tesa/carfactory#IV_Shift2_2026"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
        <tesa:checkedIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:checkedIndicator>
      </tesa:Action>
    </tesa:hasAction>
