#################################################################
# Time triggers (tesa:TimeTrigger) with OWL-Time descriptions
#################################################################

cf:TT_DailyShiftStart_North_time a time:GeneralDateTimeDescription , owl:NamedIndividual ;
    time:hour "6"^^xsd:nonNegativeInteger .

cf:TT_DailyShiftStart_North a tesa:TimeTrigger , owl:NamedIndividual ;
    rdfs:label "Daily day-shift start at Plant North" ;
    tesa:hasTriggerTime cf:TT_DailyShiftStart_North_time ;
    tesa:validDuringInterval cf:IV_Shift1_2026 ;
    tesa:hasAction cf:A_StartConveyor_North , cf:A_ActivateWelding_North .

cf:TT_DailyShiftStart_East_time a time:GeneralDateTimeDescription , owl:NamedIndividual ;
    time:hour "6"^^xsd:nonNegativeInteger .

cf:TT_DailyShiftStart_East a tesa:TimeTrigger , owl:NamedIndividual ;
    rdfs:label "Daily day-shift start at Plant East" ;
    tesa:hasTriggerTime cf:TT_DailyShiftStart_East_time ;
    tesa:validDuringInterval cf:IV_Shift1_2026 ;
    tesa:hasAction cf:A_StartConveyor_East .

cf:TT_EveningShiftStart_time a time:GeneralDateTimeDescription , owl:NamedIndividual ;
    time:hour "14"^^xsd:nonNegativeInteger .

cf:TT_EveningShiftStart a tesa:TimeTrigger , owl:NamedIndividual ;
    rdfs:label "Evening shift start, both plants" ;
    tesa:hasTriggerTime cf:TT_EveningShiftStart_time ;
    tesa:validDuringInterval cf:IV_Shift2_2026 ;
    tesa:hasAction cf:A_RotateInspectors .

cf:TT_NightWindowStart_time a time:GeneralDateTimeDescription , owl:NamedIndividual ;
    time:hour "22"^^xsd:nonNegativeInteger .

cf:TT_NightWindowStart a tesa:TimeTrigger , owl:NamedIndividual ;
    rdfs:label "Night window start" ;
    tesa:hasTriggerTime cf:TT_NightWindowStart_time ;
    tesa:validDuringInterval cf:IV_NightWindow_2026 ;
    tesa:hasAction cf:A_ChargeEVBatteries , cf:A_StopConveyor_North , cf:A_StopConveyor_East .

cf:TT_WeeklyMaintenance_time a time:GeneralDateTimeDescription , owl:NamedIndividual ;
    time:dayOfWeek time:Friday ;
    time:hour "22"^^xsd:nonNegativeInteger .

cf:TT_WeeklyMaintenance a tesa:TimeTrigger , owl:NamedIndividual ;
    rdfs:label "Weekly maintenance, Friday 22:00" ;
    tesa:hasTriggerTime cf:TT_WeeklyMaintenance_time ;
    tesa:validDuringInterval cf:IV_MaintenanceWeekend ;
    tesa:hasAction cf:A_LockdownStations , cf:A_LubricateConveyor .

cf:TT_WeldingCalibration_time a time:GeneralDateTimeDescription , owl:NamedIndividual ;
    time:dayOfWeek time:Sunday ;
    time:hour "4"^^xsd:nonNegativeInteger .

cf:TT_WeldingCalibration a tesa:TimeTrigger , owl:NamedIndividual ;
    rdfs:label "Welding calibration, Sunday 04:00" ;
    tesa:hasTriggerTime cf:TT_WeldingCalibration_time ;
    tesa:validDuringInterval cf:IV_MaintenanceWeekend ;
    tesa:hasAction cf:A_CalibrateWeldingRobots .

cf:TT_MonthlyAudit_time a time:GeneralDateTimeDescription , owl:NamedIndividual ;
