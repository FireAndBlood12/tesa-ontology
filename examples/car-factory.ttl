cf:IV_MaintenanceWeekend_beg a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-07-10T22:00:00Z"^^xsd:dateTimeStamp .

cf:IV_MaintenanceWeekend_end a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-07-13T06:00:00Z"^^xsd:dateTimeStamp .

cf:IV_HolidayShutdown a time:Interval , owl:NamedIndividual ;
