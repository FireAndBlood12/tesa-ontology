cf:IV_Q3_2026_end a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-09-30T23:59:59Z"^^xsd:dateTimeStamp .

cf:IV_SummerSchedule a time:Interval , owl:NamedIndividual ;
