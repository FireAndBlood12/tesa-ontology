#################################################################
# Conflict groups (tesa:ConflictedActions)
#################################################################

cf:CA_PaintBoothContention a tesa:ConflictedActions , owl:NamedIndividual ;
    rdfs:label "Shared paint booth: sedan vs SUV batch vs pre-heat" ;
    tesa:hasAction cf:A_PaintSedanBatch , cf:A_PaintSUVBatch , cf:A_PreheatPaintBooth .

cf:A_PaintSedanBatch tesa:conflictsWith cf:A_PaintSUVBatch .
cf:A_PaintSedanBatch tesa:conflictsWith cf:A_PreheatPaintBooth .
cf:A_PaintSUVBatch tesa:conflictsWith cf:A_PreheatPaintBooth .

cf:CA_EnergyPeak a tesa:ConflictedActions , owl:NamedIndividual ;
    rdfs:label "Energy-peak reduction vs Q3 production boost vs overtime" ;
    tesa:hasAction cf:A_ReduceEnergyLoad , cf:A_BoostProduction , cf:A_OvertimeWindow .

cf:A_ReduceEnergyLoad tesa:conflictsWith cf:A_BoostProduction .
cf:A_ReduceEnergyLoad tesa:conflictsWith cf:A_OvertimeWindow .
cf:A_BoostProduction tesa:conflictsWith cf:A_OvertimeWindow .

cf:CA_MaintenanceVsProduction a tesa:ConflictedActions , owl:NamedIndividual ;
    rdfs:label "Maintenance lockdown vs production resume" ;
    tesa:hasAction cf:A_LockdownStations , cf:A_ResumeProduction .

cf:A_LockdownStations tesa:conflictsWith cf:A_ResumeProduction .

cf:CA_ConveyorState_North a tesa:ConflictedActions , owl:NamedIndividual ;
    rdfs:label "Conveyor start vs stop, Plant North" ;
    tesa:hasAction cf:A_StartConveyor_North , cf:A_StopConveyor_North .

cf:A_StartConveyor_North tesa:conflictsWith cf:A_StopConveyor_North .

cf:CA_FirmwareVsDiagnostics a tesa:ConflictedActions , owl:NamedIndividual ;
    rdfs:label "Firmware update vs diagnostics in the same window" ;
    tesa:hasAction cf:A_UpdateRobotFirmware , cf:A_RunDiagnostics .

cf:A_UpdateRobotFirmware tesa:conflictsWith cf:A_RunDiagnostics .

cf:CA_Changeover a tesa:ConflictedActions , owl:NamedIndividual ;
    rdfs:label "Line changeover vs keeping sedan output" ;
    tesa:hasAction cf:A_ChangeoverSedanToEV , cf:A_KeepSedanOutput , cf:A_HaltForChangeover .

cf:A_ChangeoverSedanToEV tesa:conflictsWith cf:A_KeepSedanOutput .
cf:A_ChangeoverSedanToEV tesa:conflictsWith cf:A_HaltForChangeover .
cf:A_KeepSedanOutput tesa:conflictsWith cf:A_HaltForChangeover .

