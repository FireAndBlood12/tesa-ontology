cf:IV_Shift2_2026_end a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-12-18T22:00:00Z"^^xsd:dateTimeStamp .

cf:IV_NightWindow_2026 a time:Interval , owl:NamedIndividual ;
