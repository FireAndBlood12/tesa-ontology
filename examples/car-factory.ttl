    time:hasEnd cf:IV_NightWindow_2026_end .

cf:IV_NightWindow_2026_beg a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-01-05T22:00:00Z"^^xsd:dateTimeStamp .

cf:IV_NightWindow_2026_end a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-12-19T06:00:00Z"^^xsd:dateTimeStamp .

cf:IV_Q3_2026 a time:Interval , owl:NamedIndividual ;
