@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix tesa: <http://example.org/tesa#> .
@prefix cf:   <http://example.org/tesa/carfactory#> .

#################################################################
# TESA test system: car manufacturing facility
# Domain ABox used in the paper's experiments (Section 3.1).
# Six semantic levels: CorporateCenter > Division > Plant >
# ProductionLine > Station > Robot.
# All scheduling logic is expressed with the TESA constructs:
# tesa:TimeTrigger, tesa:Action, tesa:PriorityRelator,
# tesa:ConflictedActions.
#################################################################

<http://example.org/tesa/carfactory> a owl:Ontology ;
    owl:imports <http://example.org/tesa> ;
    rdfs:comment "Car factory test system for the TESA ontology: entity hierarchy, time triggers, actions, priorities and conflict groups."@en .

#################################################################
# Minimal System Domain TBox (entity model of the test system)
#################################################################

cf:Facility a owl:Class ; rdfs:label "Facility" .
cf:CorporateCenter a owl:Class ; rdfs:subClassOf cf:Facility .
cf:Division a owl:Class ; rdfs:subClassOf cf:Facility .
cf:Plant a owl:Class ; rdfs:subClassOf cf:Facility .
cf:ProductionLine a owl:Class ; rdfs:subClassOf cf:Facility .
cf:Station a owl:Class ; rdfs:subClassOf cf:Facility .
cf:WeldingCell a owl:Class ; rdfs:subClassOf cf:Station .
cf:PaintBooth a owl:Class ; rdfs:subClassOf cf:Station .
cf:AssemblyStation a owl:Class ; rdfs:subClassOf cf:Station .
cf:InspectionStation a owl:Class ; rdfs:subClassOf cf:Station .
cf:Equipment a owl:Class .
cf:Robot a owl:Class ; rdfs:subClassOf cf:Equipment .

cf:hasPart a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:domain cf:Facility ; rdfs:comment "Structural decomposition of the facility."@en .
cf:partOf a owl:ObjectProperty ; owl:inverseOf cf:hasPart .
cf:operatedBy a owl:ObjectProperty ;
    rdfs:domain cf:Station ; rdfs:range cf:Robot .
cf:appliesTo a owl:ObjectProperty ;
    rdfs:domain tesa:Action ; rdfs:range cf:Facility ;
    rdfs:comment "Links a TESA action to the facility element it controls."@en .

#################################################################
# Entity hierarchy (levels 1-6)
#################################################################

cf:CC_Global a cf:CorporateCenter , owl:NamedIndividual ;
    rdfs:label "Global Corporate Center" ;
    cf:hasPart cf:Div_Manufacturing , cf:Div_Quality , cf:Div_Logistics .

cf:Div_Manufacturing a cf:Division , owl:NamedIndividual ;
    rdfs:label "Manufacturing Division" ;
    cf:hasPart cf:Plant_North , cf:Plant_East .

cf:Div_Quality a cf:Division , owl:NamedIndividual ;
    rdfs:label "Quality Assurance Division" .

cf:Div_Logistics a cf:Division , owl:NamedIndividual ;
    rdfs:label "Logistics Division" .

cf:Plant_North a cf:Plant , owl:NamedIndividual ;
    rdfs:label "Plant North" ;
    cf:hasPart cf:PL_North_Sedan , cf:PL_North_SUV , cf:PL_North_EV .

cf:Plant_East a cf:Plant , owl:NamedIndividual ;
    rdfs:label "Plant East" ;
    cf:hasPart cf:PL_East_Sedan , cf:PL_East_SUV , cf:PL_East_EV .

cf:PL_North_Sedan a cf:ProductionLine , owl:NamedIndividual ;
    rdfs:label "PL North Sedan" ;
    cf:hasPart cf:ST_North_Sedan_WEL , cf:ST_North_Sedan_PNT , cf:ST_North_Sedan_ASM , cf:ST_North_Sedan_INS .

cf:PL_North_EV a cf:ProductionLine , owl:NamedIndividual ;
    rdfs:label "PL North EV" ;
    cf:hasPart cf:ST_North_EV_WEL , cf:ST_North_EV_PNT , cf:ST_North_EV_ASM , cf:ST_North_EV_INS .

cf:PL_East_SUV a cf:ProductionLine , owl:NamedIndividual ;
    rdfs:label "PL East SUV" ;
    cf:hasPart cf:ST_East_SUV_WEL , cf:ST_East_SUV_PNT , cf:ST_East_SUV_ASM , cf:ST_East_SUV_INS .

cf:PL_North_SUV a cf:ProductionLine , owl:NamedIndividual ;
    rdfs:label "PL North SUV" ;
    cf:hasPart cf:ST_North_SUV_WEL , cf:ST_North_SUV_PNT .

cf:PL_East_Sedan a cf:ProductionLine , owl:NamedIndividual ;
    rdfs:label "PL East Sedan" ;
    cf:hasPart cf:ST_East_Sedan_WEL , cf:ST_East_Sedan_PNT .

cf:PL_East_EV a cf:ProductionLine , owl:NamedIndividual ;
    rdfs:label "PL East EV" ;
    cf:hasPart cf:ST_East_EV_WEL , cf:ST_East_EV_PNT .

cf:ST_North_Sedan_WEL a cf:WeldingCell , owl:NamedIndividual ;
