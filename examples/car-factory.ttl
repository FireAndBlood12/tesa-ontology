#################################################################
# Validity intervals (OWL-Time)
#################################################################

cf:IV_Shift1_2026 a time:Interval , owl:NamedIndividual ;
    rdfs:label "Day shift window, production year 2026" ;
    time:hasBeginning cf:IV_Shift1_2026_beg ;
    time:hasEnd cf:IV_Shift1_2026_end .

cf:IV_Shift1_2026_beg a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-01-05T06:00:00Z"^^xsd:dateTimeStamp .

cf:IV_Shift1_2026_end a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-12-18T14:00:00Z"^^xsd:dateTimeStamp .

cf:IV_Shift2_2026 a time:Interval , owl:NamedIndividual ;
    rdfs:label "Evening shift window" ;
