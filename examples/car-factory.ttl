cf:IV_SafetyDrill_Jul a time:Interval , owl:NamedIndividual ;
    rdfs:label "July safety drill" ;
    time:hasBeginning cf:IV_SafetyDrill_Jul_beg ;
    time:hasEnd cf:IV_SafetyDrill_Jul_end .

cf:IV_SafetyDrill_Jul_beg a time:Instant , owl:NamedIndividual ;
    time:inXSDDateTimeStamp "2026-07-15T10:00:00Z"^^xsd:dateTimeStamp .

