<owl:NamedIndividual rdf:about="#StartAction_5">
  <rdf:type rdf:resource="#Action"/>
  <affectsMachine rdf:resource="#Machine_5"/>
  <actionType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">START</actionType>
