<owl:NamedIndividual rdf:about="#StopAction_2">
  <rdf:type rdf:resource="#Action"/>
  <affectsMachine rdf:resource="#Machine_2"/>
  <actionType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">STOP</actionType>
