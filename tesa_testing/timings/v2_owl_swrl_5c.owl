</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Machine_4">
  <rdf:type rdf:resource="#Machine"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#StartAction_4">
  <rdf:type rdf:resource="#Action"/>
  <affectsMachine rdf:resource="#Machine_4"/>
