<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/owl_swrl_comparison"
         xmlns="http://www.semanticweb.org/owl_swrl_comparison#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://www.semanticweb.org/owl_swrl_comparison"/>

<owl:ObjectProperty rdf:about="#affectsMachine">
  <rdfs:domain rdf:resource="#Action"/>
  <rdfs:range rdf:resource="#Machine"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#actionType">
  <rdfs:domain rdf:resource="#Action"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#priorityValue">
  <rdfs:domain rdf:resource="#Action"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Machine">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Action">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#ActiveState">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <owl:disjointWith rdf:resource="#StoppedState"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">State indicating active operation</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#StoppedState">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">State indicating stopped operation</rdfs:comment>
</owl:Class>

<owl:NamedIndividual rdf:about="#Machine_1">
  <rdf:type rdf:resource="#Machine"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#StartAction_1">
  <rdf:type rdf:resource="#Action"/>
  <affectsMachine rdf:resource="#Machine_1"/>
  <actionType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">START</actionType>
  <priorityValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">21</priorityValue>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#StopAction_1">
  <rdf:type rdf:resource="#Action"/>
  <affectsMachine rdf:resource="#Machine_1"/>
  <actionType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">STOP</actionType>
  <priorityValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">51</priorityValue>
</owl:NamedIndividual>

