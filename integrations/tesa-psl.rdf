<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:psl="http://www.mel.nist.gov/psl/psl-core#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:time="http://www.w3.org/2006/time#"
  xmlns:tesa="http://example.org/tesa#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <psl:ActivityOccurrence rdf:about="http://example.org/tesa/examples/psl#Occ_2026w28">
    <psl:occurrence_of>
      <psl:Activity rdf:about="http://example.org/tesa/examples/psl#A_Maintenance_psl">
        <owl:sameAs rdf:resource="http://example.org/tesa/examples/psl#A_Maintenance"/>
      </psl:Activity>
    </psl:occurrence_of>
    <psl:beginof>
      <psl:Timepoint rdf:about="http://example.org/tesa/examples/psl#tp_2026_07_10_2200">
        <rdf:type rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <time:inXSDDateTimeStamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTimeStamp">2026-07-10T22:00:00Z</time:inXSDDateTimeStamp>
      </psl:Timepoint>
    </psl:beginof>
    <psl:endof>
      <psl:Timepoint rdf:about="http://example.org/tesa/examples/psl#tp_2026_07_11_0600">
        <rdf:type rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <time:inXSDDateTimeStamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTimeStamp">2026-07-11T06:00:00Z</time:inXSDDateTimeStamp>
      </psl:Timepoint>
    </psl:endof>
  </psl:ActivityOccurrence>
  <psl:ActivityOccurrence rdf:about="http://example.org/tesa/examples/psl#Occ_2026w29">
    <psl:occurrence_of rdf:resource="http://example.org/tesa/examples/psl#A_Maintenance_psl"/>
    <psl:beginof>
      <psl:Timepoint rdf:about="http://example.org/tesa/examples/psl#tp_2026_07_17_2200">
        <rdf:type rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <time:inXSDDateTimeStamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTimeStamp">2026-07-17T22:00:00Z</time:inXSDDateTimeStamp>
      </psl:Timepoint>
    </psl:beginof>
    <psl:endof>
      <psl:Timepoint rdf:about="http://example.org/tesa/examples/psl#tp_2026_07_18_0600">
        <rdf:type rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <time:inXSDDateTimeStamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTimeStamp">2026-07-18T06:00:00Z</time:inXSDDateTimeStamp>
      </psl:Timepoint>
    </psl:endof>
  </psl:ActivityOccurrence>
  <owl:ObjectProperty rdf:about="http://www.mel.nist.gov/psl/psl-core#occurrence_of">
    <rdfs:domain rdf:resource="http://www.mel.nist.gov/psl/psl-core#ActivityOccurrence"/>
    <rdfs:range rdf:resource="http://www.mel.nist.gov/psl/psl-core#Activity"/>
  </owl:ObjectProperty>
  <owl:Ontology rdf:about="http://example.org/tesa/integrations/psl">
    <owl:imports rdf:resource="http://example.org/tesa"/>
    <rdfs:comment xml:lang="en">Interoperability module between TESA and an OWL rendering of PSL-Core (ISO 18629).</rdfs:comment>
  </owl:Ontology>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/examples/psl#TT_Maintenance">
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/examples/psl#FridayNight">
        <time:dayOfWeek rdf:resource="http://www.w3.org/2006/time#Friday"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">22</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/examples/psl#A_Maintenance">
        <rdfs:label>Weekly maintenance</rdfs:label>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
      </tesa:Action>
    </tesa:hasAction>
  </tesa:TimeTrigger>
  <owl:ObjectProperty rdf:about="http://www.mel.nist.gov/psl/psl-core#endof">
    <rdfs:domain rdf:resource="http://www.mel.nist.gov/psl/psl-core#ActivityOccurrence"/>
    <rdfs:range rdf:resource="http://www.mel.nist.gov/psl/psl-core#Timepoint"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.mel.nist.gov/psl/psl-core#beginof">
    <rdfs:domain rdf:resource="http://www.mel.nist.gov/psl/psl-core#ActivityOccurrence"/>
    <rdfs:range rdf:resource="http://www.mel.nist.gov/psl/psl-core#Timepoint"/>
  </owl:ObjectProperty>
  <owl:Class rdf:about="http://www.mel.nist.gov/psl/psl-core#Activity">
    <rdfs:label>activity</rdfs:label>
    <skos:note xml:lang="en">PSL-Core: a repeatable pattern of behavior.</skos:note>
  </owl:Class>
  <owl:Class rdf:about="http://www.mel.nist.gov/psl/psl-core#ActivityOccurrence">
    <rdfs:label>activity_occurrence</rdfs:label>
    <skos:note xml:lang="en">PSL-Core: a concrete, temporally bounded happening of an activity.</skos:note>
  </owl:Class>
  <owl:Class rdf:about="http://www.mel.nist.gov/psl/psl-core#Timepoint">
    <rdfs:label>timepoint</rdfs:label>
  </owl:Class>
  <rdf:Description rdf:about="http://www.w3.org/2006/time#Instant">
    <rdfs:subClassOf rdf:resource="http://www.mel.nist.gov/psl/psl-core#Timepoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tesa#Action">
    <rdfs:subClassOf rdf:resource="http://www.mel.nist.gov/psl/psl-core#Activity"/>
  </rdf:Description>
</rdf:RDF>
