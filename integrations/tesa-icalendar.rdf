<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:ical="http://www.w3.org/2002/12/cal/ical#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:tesa="http://example.org/tesa#"
  xmlns:time="http://www.w3.org/2006/time#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/12/cal/ical#priority"/>
  <owl:ObjectProperty rdf:about="http://www.w3.org/2002/12/cal/ical#component">
    <rdfs:domain rdf:resource="http://www.w3.org/2002/12/cal/ical#Vcalendar"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/12/cal/ical#Vevent"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/12/cal/ical#rrule"/>
  <owl:ObjectProperty rdf:about="http://example.org/tesa#hasICalExport">
    <rdfs:domain rdf:resource="http://example.org/tesa#TimeTrigger"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/12/cal/ical#Vevent"/>
    <rdfs:comment xml:lang="en">Connects a TESA trigger to its published calendar representation.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/12/cal/ical#dtend"/>
  <owl:Ontology rdf:about="http://example.org/tesa/integrations/ical">
    <owl:imports rdf:resource="http://example.org/tesa"/>
    <rdfs:comment xml:lang="en">Round-trip interoperability module between TESA schedules and iCalendar (RDF Calendar / RFC 5545).</rdfs:comment>
  </owl:Ontology>
  <tesa:TimeTrigger rdf:about="http://example.org/tesa/examples/ical#TT_Maintenance">
    <rdfs:label>Weekly maintenance, Friday 22:00</rdfs:label>
    <tesa:hasTriggerTime>
      <time:GeneralDateTimeDescription rdf:about="http://example.org/tesa/examples/ical#FridayNight">
        <time:dayOfWeek rdf:resource="http://www.w3.org/2006/time#Friday"/>
        <time:hour rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">22</time:hour>
      </time:GeneralDateTimeDescription>
    </tesa:hasTriggerTime>
    <tesa:hasAction>
      <tesa:Action rdf:about="http://example.org/tesa/examples/ical#A_Maintenance">
        <rdfs:label>Weekly maintenance lockdown</rdfs:label>
        <tesa:hasPriorityRelator rdf:resource="http://example.org/tesa/examples/ical#PR_Maint"/>
        <tesa:executeIndicator rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tesa:executeIndicator>
      </tesa:Action>
    </tesa:hasAction>
    <tesa:hasICalExport>
      <ical:Vevent rdf:about="http://example.org/tesa/examples/ical#EV_Maintenance">
        <ical:summary>Plant maintenance lockdown (auto-published from TESA)</ical:summary>
        <ical:dtstart rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-01-09T22:00:00+00:00</ical:dtstart>
        <ical:dtend rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-01-10T06:00:00+00:00</ical:dtend>
        <ical:rrule>FREQ=WEEKLY;BYDAY=FR;UNTIL=20261218T220000Z</ical:rrule>
        <ical:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</ical:priority>
        <skos:note xml:lang="en">Advisory only: arbitration between conflicting events is performed by the TESA priority mechanism, not by the calendar.</skos:note>
      </ical:Vevent>
    </tesa:hasICalExport>
  </tesa:TimeTrigger>
  <ical:Vcalendar rdf:about="http://example.org/tesa/examples/ical#CrewCalendar">
    <ical:component rdf:resource="http://example.org/tesa/examples/ical#EV_Maintenance"/>
  </ical:Vcalendar>
  <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/12/cal/ical#dtstart"/>
  <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/12/cal/ical#summary"/>
  <owl:Class rdf:about="http://www.w3.org/2002/12/cal/ical#Vevent"/>
  <tesa:PriorityRelator rdf:about="http://example.org/tesa/examples/ical#PR_Maint">
    <tesa:priorityValue rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">9</tesa:priorityValue>
  </tesa:PriorityRelator>
  <owl:Class rdf:about="http://www.w3.org/2002/12/cal/ical#Vcalendar"/>
</rdf:RDF>
