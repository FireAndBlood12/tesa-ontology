@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tesa: <http://example.org/tesa#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tesa:ConflictedActions rdfs:subClassOf gufo:Collection .

tesa:TimeTrigger rdfs:subClassOf gufo:Situation ;
    skos:note "The satisfaction of a time trigger is a situation that brings about the associated events."@en .

tesa:UFOProbe_Action a tesa:Action,
        owl:NamedIndividual ;
    rdfs:label "UFO alignment probe action" ;
    tesa:executeIndicator false ;
    tesa:hasPriorityRelator tesa:UFOProbe_PR .

<http://example.org/tesa/align/ufo> a owl:Ontology ;
    rdfs:comment "Bridge axioms aligning the TESA scheduling constructs with UFO categories through gUFO."@en ;
    owl:imports <http://example.org/tesa> .

tesa:Action a gufo:EventType ;
    rdfs:subClassOf gufo:Event ;
    skos:note "In gUFO, domain event classes are instances of gufo:EventType; TESA actions are the event type of scheduled system behaviors."@en .

tesa:PriorityRelator rdfs:subClassOf gufo:Relator ;
    skos:note "A PriorityRelator mediates the priority ordering between conflicting actions, exactly matching the UFO notion of a relator."@en .

tesa:UFOProbe_PR a tesa:PriorityRelator,
        owl:NamedIndividual ;
    tesa:priorityValue "9"^^xsd:nonNegativeInteger .

gufo:Collection a owl:Class ;
    rdfs:label "Collection"@en .

gufo:Event a owl:Class ;
    rdfs:label "Event"@en .

gufo:EventType a owl:Class ;
    rdfs:label "EventType"@en .

gufo:Relator a owl:Class ;
    rdfs:label "Relator"@en .

gufo:Situation a owl:Class ;
    rdfs:label "Situation"@en .

