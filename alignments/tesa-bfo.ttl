@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix tesa: <http://example.org/tesa#> .
@prefix obo:  <http://purl.obolibrary.org/obo/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

#################################################################
# TESA -> BFO 2.0 alignment module
#
# Demonstrates that TESA can be layered on top of Basic Formal
# Ontology (BFO) without redefining any BFO axiom: every bridge
# statement is an additive rdfs:subClassOf assertion, so the
# import closure stays in OWL 2 DL and remains consistent.
#################################################################

<http://example.org/tesa/align/bfo> a owl:Ontology ;
    owl:imports <http://example.org/tesa> ;
    owl:imports <http://purl.obolibrary.org/obo/bfo.owl> ;
    rdfs:comment "Bridge axioms aligning the TESA scheduling constructs with BFO 2.0 top-level categories."@en .

### Local declarations of the referenced BFO classes (self-containment)
obo:BFO_0000015 a owl:Class ; rdfs:label "process"@en .
obo:BFO_0000031 a owl:Class ; rdfs:label "generically dependent continuant"@en .
obo:BFO_0000038 a owl:Class ; rdfs:label "one-dimensional temporal region"@en .
obo:BFO_0000008 a owl:Class ; rdfs:label "temporal region"@en .
obo:BFO_0000038 rdfs:subClassOf obo:BFO_0000008 .

#################################################################
# Bridge axioms
#################################################################

# A TESA action, once executed, unfolds in time: it is a BFO process.
tesa:Action rdfs:subClassOf obo:BFO_0000015 ;
    skos:note "TESA actions denote planned processes of the cyber-physical system; their realizations are BFO processes occupying a temporal region given by tesa:validDuringInterval."@en .

# A time trigger is a directive information entity: it prescribes when
# actions must be initiated, and it can be copied between systems.
tesa:TimeTrigger rdfs:subClassOf obo:BFO_0000031 ;
    skos:note "Time-based directives are generically dependent continuants (information entities): the same trigger can be concretized in many digital twins."@en .

# A priority relator is likewise an information entity that assigns
# an ordering to actions.
tesa:PriorityRelator rdfs:subClassOf obo:BFO_0000031 .

# A conflict registry is an information entity that groups actions.
tesa:ConflictedActions rdfs:subClassOf obo:BFO_0000031 .

# OWL-Time intervals used by TESA are one-dimensional temporal regions.
time:Interval rdfs:subClassOf obo:BFO_0000038 .
time:Instant rdfs:subClassOf obo:BFO_0000008 .

#################################################################
# Consistency probe: one fully described action in BFO context.
# If the bridge axioms were incompatible, the reasoner would
# report an inconsistency on this individual.
#################################################################

tesa:BFOProbe_Interval a time:Interval , owl:NamedIndividual .
tesa:BFOProbe_Action a tesa:Action , owl:NamedIndividual ;
    rdfs:label "BFO alignment probe action" ;
    tesa:executeIndicator "false"^^xsd:boolean ;
    tesa:validDuringInterval tesa:BFOProbe_Interval .
