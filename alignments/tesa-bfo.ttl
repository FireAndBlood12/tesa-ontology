@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tesa: <http://example.org/tesa#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tesa:BFOProbe_Action a tesa:Action,
        owl:NamedIndividual ;
    rdfs:label "BFO alignment probe action" ;
    tesa:executeIndicator false ;
    tesa:validDuringInterval tesa:BFOProbe_Interval .

tesa:ConflictedActions rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000031> .

tesa:PriorityRelator rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000031> .

tesa:TimeTrigger rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000031> ;
    skos:note "Time-based directives are generically dependent continuants (information entities): the same trigger can be concretized in many digital twins."@en .

<http://example.org/tesa/align/bfo> a owl:Ontology ;
    rdfs:comment "Bridge axioms aligning the TESA scheduling constructs with BFO 2.0 top-level categories."@en ;
    owl:imports <http://example.org/tesa> .

time:Instant rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000008> .

tesa:Action rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
    skos:note "TESA actions denote planned processes of the cyber-physical system; their realizations are BFO processes occupying a temporal region given by tesa:validDuringInterval."@en .

tesa:BFOProbe_Interval a owl:NamedIndividual,
        time:Interval .

<http://purl.obolibrary.org/obo/BFO_0000015> a owl:Class ;
    rdfs:label "process"@en .

<http://purl.obolibrary.org/obo/BFO_0000038> a owl:Class ;
    rdfs:label "one-dimensional temporal region"@en ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000008> .

time:Interval rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000038> .

<http://purl.obolibrary.org/obo/BFO_0000008> a owl:Class ;
    rdfs:label "temporal region"@en .

<http://purl.obolibrary.org/obo/BFO_0000031> a owl:Class ;
    rdfs:label "generically dependent continuant"@en .

