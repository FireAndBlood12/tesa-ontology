@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tesa: <http://example.org/tesa#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tesa:ConflictedActions rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Collection> .

tesa:DULProbe_Trigger a tesa:TimeTrigger,
        owl:NamedIndividual ;
    rdfs:label "DUL alignment probe trigger" ;
    tesa:hasAction tesa:DULProbe_Action .

tesa:PriorityRelator rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Parameter> .

<http://example.org/tesa/align/dolce> a owl:Ontology ;
    rdfs:comment "Bridge axioms aligning the TESA scheduling constructs with DOLCE through DUL."@en ;
    owl:imports <http://example.org/tesa> .

time:Interval rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval> .

tesa:Action rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Action> .

tesa:DULProbe_Action a tesa:Action,
        owl:NamedIndividual ;
    tesa:executeIndicator false .

tesa:TimeTrigger rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description> ;
    skos:note "A trigger describes the conditions (time pattern + validity interval) that classify the situations in which the linked actions must run."@en .

<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Action> a owl:Class ;
    rdfs:label "Action"@en ;
    rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Event> .

<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Collection> a owl:Class ;
    rdfs:label "Collection"@en .

<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description> a owl:Class ;
    rdfs:label "Description"@en .

<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Event> a owl:Class ;
    rdfs:label "Event"@en .

<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Parameter> a owl:Class ;
    rdfs:label "Parameter"@en .

<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval> a owl:Class ;
    rdfs:label "TimeInterval"@en .

