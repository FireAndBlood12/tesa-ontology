@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tesa: <http://example.org/tesa#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tesa:PriorityRelator rdfs:subClassOf <http://www.ontologyportal.org/SUMO.owl#RelationalAttribute> .

tesa:SUMOProbe_Group a tesa:ConflictedActions,
        owl:NamedIndividual ;
    tesa:hasAction tesa:SUMOProbe_Action .

tesa:TimeTrigger rdfs:subClassOf <http://www.ontologyportal.org/SUMO.owl#Procedure> ;
    skos:note "SUMO Procedure is a sequence-of-instructions content class; a TESA trigger prescribes the initiation of actions under temporal conditions."@en .

<http://example.org/tesa/align/sumo> a owl:Ontology ;
    rdfs:comment "Bridge axioms aligning the TESA scheduling constructs with SUMO categories (OWL export)."@en ;
    owl:imports <http://example.org/tesa> .

time:Instant rdfs:subClassOf <http://www.ontologyportal.org/SUMO.owl#TimePoint> .

time:Interval rdfs:subClassOf <http://www.ontologyportal.org/SUMO.owl#TimeInterval> .

tesa:Action rdfs:subClassOf <http://www.ontologyportal.org/SUMO.owl#IntentionalProcess> .

tesa:ConflictedActions rdfs:subClassOf <http://www.ontologyportal.org/SUMO.owl#Collection> .

tesa:SUMOProbe_Action a tesa:Action,
        owl:NamedIndividual ;
    rdfs:label "SUMO alignment probe action" ;
    tesa:executeIndicator false .

<http://www.ontologyportal.org/SUMO.owl#Collection> a owl:Class ;
    rdfs:label "Collection"@en .

<http://www.ontologyportal.org/SUMO.owl#IntentionalProcess> a owl:Class ;
    rdfs:subClassOf <http://www.ontologyportal.org/SUMO.owl#Process> .

<http://www.ontologyportal.org/SUMO.owl#Procedure> a owl:Class ;
    rdfs:label "Procedure"@en .

<http://www.ontologyportal.org/SUMO.owl#Process> a owl:Class ;
    rdfs:label "Process"@en .

<http://www.ontologyportal.org/SUMO.owl#RelationalAttribute> a owl:Class ;
    rdfs:label "RelationalAttribute"@en .

<http://www.ontologyportal.org/SUMO.owl#TimeInterval> a owl:Class ;
    rdfs:label "TimeInterval"@en .

<http://www.ontologyportal.org/SUMO.owl#TimePoint> a owl:Class ;
    rdfs:label "TimePoint"@en .

